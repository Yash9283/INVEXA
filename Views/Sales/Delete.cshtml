@model StockFlow.Models.Sale

@{
    Layout = "_AdminLayout";
}

<h2>Delete Sale</h2>

<div class="alert alert-danger">

    <h5>Are you sure you want to delete this sale?</h5>

    <hr />

    <p><strong>Product:</strong> @Model.ProductName</p>
    <p><strong>Customer:</strong> @Model.CustomerName</p>
    <p><strong>Total:</strong> ₹@Model.TotalAmount</p>

    <form asp-action="Delete">

        <input type="hidden" asp-for="Id" />

        <button class="btn btn-danger">
            Delete
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Cancel
        </a>

    </form>

</div>