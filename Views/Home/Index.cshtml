@{
    Layout = "_AdminLayout";
}
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">

    <h2>📊 Admin Console</h2>

    <div class="row">

        <div class="col-md-3 mb-3">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <h5>Total Products</h5>
                    <h2>120</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <h5>Categories</h5>
                    <h2>15</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card text-white bg-warning">
                <div class="card-body">
                    <h5>Customers</h5>
                    <h2>60</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card text-white bg-danger">
                <div class="card-body">
                    <h5>Sales</h5>
                    <h2>250</h2>
                </div>
            </div>
        </div>

    </div>

    <div class="card mt-4">
        <div class="card-header">
            Recent Activity
        </div>

        <div class="card-body">
            <ul>
                <li>New Product Added</li>
                <li>Stock Updated</li>
                <li>Supplier Added</li>
                <li>New Sale Recorded</li>
            </ul>
        </div>
    </div>

</div>