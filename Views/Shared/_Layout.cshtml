@using Microsoft.AspNetCore.Http

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StockNova</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>
    
    <div class="app">

        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div class="brand">
                <i class="bi bi-box-seam-fill"></i>
                <div>
                    <h4 class="mb-0 fw-bold">StockNova</h4>
                    <small>WorkSpace</small>
                </div>
            </div>

            <ul class="sidebar-menu">
                <li>
                    <a asp-controller="Home" asp-action="Index">
                        <i class="bi bi-speedometer2"></i>
                        <span>Dashboard</span>
                    </a>
                </li>

                <li class="menu-title">INVENTORY</li>

                <li>
                    <a asp-controller="Product" asp-action="Index">
                        <i class="bi bi-box"></i>
                        <span>Products</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Category" asp-action="Index">
                        <i class="bi bi-tags"></i>
                        <span>Categories</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Supplier" asp-action="Index">
                        <i class="bi bi-truck"></i>
                        <span>Suppliers</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Customer" asp-action="Index">
                        <i class="bi bi-people"></i>
                        <span>Customers</span>
                    </a>
                </li>

                <li class="menu-title">SALES</li>

                <li>
                    <a asp-controller="Sales" asp-action="Index">
                        <i class="bi bi-cart-check"></i>
                        <span>Sales</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Invoice" asp-action="Index">
                        <i class="bi bi-receipt-cutoff"></i>
                        <span>Invoices</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="Report" asp-action="Index">
                        <i class="bi bi-bar-chart"></i>
                        <span>Reports</span>
                    </a>
                </li>

                <li class="menu-title">SYSTEM</li>

                <li>
                    <a href="#">
                        <i class="bi bi-bell"></i>
                        <span>Notifications</span>
                        <span class="badge bg-danger ms-auto">3</span>
                    </a>
                </li>
                <li>
                    <a href="#">
                        <i class="bi bi-gear"></i>
                        <span>Settings</span>
                    </a>
                </li>
            </ul>

            <div class="logout">
                <a asp-controller="Account" asp-action="Logout">
                    <i class="bi bi-box-arrow-right"></i>
                    Logout
                </a>
            </div>
        </aside>

        <!-- MAIN -->
        <section class="main">
            <header class="topbar">
                <div>
                    <h4 class="fw-bold mb-0">🚀 StockNova Nexus Console</h4>
                    <small class="text-muted">Smart Inventory • Sales • Analytics</small>
                </div>

                <div class="d-flex align-items-center">

                    <!-- Search -->
                    <div class="me-3">
                        <div class="input-group">
                            <span class="input-group-text bg-white">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" class="form-control" placeholder="Search Products...">
                        </div>
                    </div>

                    <!-- Notifications -->
                    <div class="dropdown me-3">
                        <button class="btn btn-light position-relative" data-bs-toggle="dropdown">
                            <i class="bi bi-bell fs-5"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">3</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow">
                            <li><h6 class="dropdown-header">Notifications</h6></li>
                            <li><a class="dropdown-item" href="#">⚠ Mouse stock is low</a></li>
                            <li><a class="dropdown-item" href="#">🛒 New Sale Completed</a></li>
                            <li><a class="dropdown-item" href="#">👤 New Customer Registered</a></li>
                        </ul>
                    </div>

                    <!-- Dark Mode -->
                    <button id="themeToggle" class="btn btn-outline-secondary me-3">
                        <i class="bi bi-moon-fill" id="themeIcon"></i>
                    </button>

                    <!-- Admin -->
                    <div class="dropdown">
                        <a href="#" class="admin-user dropdown-toggle text-decoration-none" data-bs-toggle="dropdown">
                            <img src="https://ui-avatars.com/api/?name=Admin&background=2563eb&color=fff" width="40" class="rounded-circle me-2" />
                            <strong>@Context.Session.GetString("Username")</strong>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow">
                            <li>
                                <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                    <i class="bi bi-person"></i> My Profile
                                </a>
                            </li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-gear"></i> Settings</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-key"></i> Change Password</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right"></i> Logout
                                </a>
                            </li>
                        </ul>
                    </div>

                </div>
            </header>

            <div class="page-content">
                @RenderBody()
            </div>

        </section>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
   
    <script>
        const btn = document.getElementById("themeToggle");
        const icon = document.getElementById("themeIcon");

        if (localStorage.getItem("theme") === "dark") {
            document.body.classList.add("dark-mode");
            icon.className = "bi bi-sun-fill";
        }

        btn.addEventListener("click", function () {
            document.body.classList.toggle("dark-mode");
            if (document.body.classList.contains("dark-mode")) {
                localStorage.setItem("theme", "dark");
                icon.className = "bi bi-sun-fill";
            } else {
                localStorage.setItem("theme", "light");
                icon.className = "bi bi-moon-fill";
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>