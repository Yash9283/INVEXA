@model StockFlow.Models.Invoice

@{
    ViewData["Title"] = "Delete Invoice";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid px-4">

    <div class="mb-4">
        <h3 class="fw-bold mb-1 text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Delete Invoice</h3>
        <p class="text-muted mb-0">Are you sure you want to delete this invoice?</p>
    </div>

    <div class="card shadow-sm border-0" style="max-width: 640px;">
        <div class="card-body p-4">

            <dl class="row mb-4">
                <dt class="col-sm-4">Invoice Number</dt>
                <dd class="col-sm-8">@Model.InvoiceNumber</dd>

                <dt class="col-sm-4">Customer Name</dt>
                <dd class="col-sm-8">@Model.CustomerName</dd>

                <dt class="col-sm-4">Product</dt>
                <dd class="col-sm-8">@Model.ProductName</dd>

                <dt class="col-sm-4">Total Amount</dt>
                <dd class="col-sm-8">₹@Model.TotalAmount</dd>

                <dt class="col-sm-4">Date</dt>
                <dd class="col-sm-8">@Model.InvoiceDate.ToString("dd-MM-yyyy")</dd>

                <dt class="col-sm-4">Status</dt>
                <dd class="col-sm-8"><span class="badge bg-success">@Model.PaymentStatus</span></dd>
            </dl>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger px-4">
                    <i class="bi bi-trash me-1"></i> Yes, Delete
                </button>
                <a asp-action="Index" class="btn btn-light px-4">Cancel</a>
            </form>

        </div>
    </div>

</div>